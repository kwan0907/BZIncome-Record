<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FIT Dashboard - 收入儀表板</title>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-auth-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore-compat.js"></script>
<script>
tailwind.config={theme:{extend:{colors:{primary:'#6366f1',primaryDk:'#4f46e5',accent:'#f59e0b',sidebar:'#1e1b4b',card:'#ffffff'}}}}
</script>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:#f1f5f9}
::-webkit-scrollbar{width:6px}
::-webkit-scrollbar-thumb{background:#c7d2fe;border-radius:3px}
.sidebar{transition:transform .3s}
.sidebar.closed{transform:translateX(-100%)}
.nav-item{transition:all .2s}
.nav-item:hover,.nav-item.active{background:rgba(255,255,255,.15);border-radius:8px}
.card{background:#fff;border-radius:12px;box-shadow:0 1px 3px rgba(0,0,0,.1)}
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:1000;display:flex;align-items:center;justify-content:center}
.modal-content{background:#fff;border-radius:16px;max-height:90vh;overflow-y:auto;width:95%;max-width:600px;padding:24px}
.badge{display:inline-flex;align-items:center;padding:2px 10px;border-radius:999px;font-size:12px;font-weight:600}
input,select,textarea{border:1px solid #e2e8f0;border-radius:8px;padding:8px 12px;width:100%;font-size:14px;outline:none;transition:border .2s}
input:focus,select:focus{border-color:#6366f1;box-shadow:0 0 0 3px rgba(99,102,241,.1)}
button{cursor:pointer;transition:all .2s}
.btn-primary{background:#6366f1;color:#fff;padding:10px 20px;border-radius:8px;border:none;font-weight:600}
.btn-primary:hover{background:#4f46e5}
.btn-secondary{background:#e2e8f0;color:#334155;padding:10px 20px;border-radius:8px;border:none;font-weight:600}
.btn-danger{background:#ef4444;color:#fff;padding:10px 20px;border-radius:8px;border:none;font-weight:600}
.tab-btn{padding:8px 16px;border:none;background:transparent;font-weight:600;color:#64748b;border-bottom:2px solid transparent}
.tab-btn.active{color:#6366f1;border-bottom-color:#6366f1}
.stat-card{transition:transform .2s}
.stat-card:hover{transform:translateY(-2px)}
.search-results{position:absolute;top:100%;left:0;right:0;background:#fff;border:1px solid #e2e8f0;border-radius:8px;max-height:200px;overflow-y:auto;z-index:50}
.search-results div{padding:8px 12px;cursor:pointer}
.search-results div:hover{background:#f1f5f9}
.toast{position:fixed;top:20px;right:20px;padding:12px 24px;border-radius:8px;color:#fff;font-weight:600;z-index:9999;animation:slideIn .3s}
@keyframes slideIn{from{transform:translateX(100%);opacity:0}to{transform:translateX(0);opacity:1}}
@media(max-width:768px){
.sidebar{position:fixed;z-index:100;width:260px}
.main-content{margin-left:0!important}
}
.product-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:12px}
.expiry-warning{animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.6}}
</style>
</head>
<body>

<!-- AUTH SECTION -->
<div id="authSection" class="min-h-screen flex items-center justify-center bg-gradient-to-br from-indigo-600 to-purple-700 p-4">
<div class="card w-full max-w-md p-8">
  <!-- Login -->
  <div id="loginView">
    <div class="text-center mb-6">
      <div class="w-16 h-16 bg-indigo-100 rounded-full flex items-center justify-center mx-auto mb-3">
        <i class="fas fa-chart-line text-2xl text-indigo-600"></i>
      </div>
      <h1 class="text-2xl font-bold text-gray-800">FIT Dashboard</h1>
      <p class="text-gray-500 text-sm mt-1">收入儀表板管理系統</p>
    </div>
    <div class="space-y-4">
      <div><label class="text-sm font-medium text-gray-700">電郵地址</label><input id="loginEmail" type="email" placeholder="your@email.com"></div>
      <div><label class="text-sm font-medium text-gray-700">密碼</label><input id="loginPass" type="password" placeholder="••••••••"></div>
      <div class="flex items-center justify-between">
        <label class="flex items-center text-sm"><input type="checkbox" id="rememberMe" class="mr-2 w-auto">記住密碼</label>
        <a href="#" onclick="showAuth('forgot')" class="text-sm text-indigo-600 hover:underline">忘記密碼？</a>
      </div>
      <button class="btn-primary w-full" onclick="doLogin()"><i class="fas fa-sign-in-alt mr-2"></i>登入</button>
      <button id="biometricBtn" class="btn-secondary w-full hidden" onclick="biometricLogin()"><i class="fas fa-fingerprint mr-2"></i>Face ID / 生物認證登入</button>
      <p class="text-center text-sm text-gray-500">還沒有帳號？<a href="#" onclick="showAuth('register')" class="text-indigo-600 font-medium hover:underline">立即註冊</a></p>
    </div>
    <div id="loginError" class="mt-3 text-red-500 text-sm text-center hidden"></div>
  </div>
  <!-- Register -->
  <div id="registerView" class="hidden">
    <div class="text-center mb-6">
      <h2 class="text-2xl font-bold text-gray-800">建立帳號</h2>
      <p class="text-gray-500 text-sm">開始使用 FIT Dashboard</p>
    </div>
    <div class="space-y-4">
      <div><label class="text-sm font-medium text-gray-700">顯示名稱</label><input id="regName" type="text" placeholder="你的名稱"></div>
      <div><label class="text-sm font-medium text-gray-700">電郵地址</label><input id="regEmail" type="email" placeholder="your@email.com"></div>
      <div><label class="text-sm font-medium text-gray-700">密碼</label><input id="regPass" type="password" placeholder="至少6位字符"></div>
      <div><label class="text-sm font-medium text-gray-700">確認密碼</label><input id="regPass2" type="password" placeholder="再次輸入密碼"></div>
      <button class="btn-primary w-full" onclick="doRegister()"><i class="fas fa-user-plus mr-2"></i>註冊</button>
      <p class="text-center text-sm text-gray-500">已有帳號？<a href="#" onclick="showAuth('login')" class="text-indigo-600 font-medium hover:underline">返回登入</a></p>
    </div>
    <div id="regError" class="mt-3 text-red-500 text-sm text-center hidden"></div>
  </div>
  <!-- Forgot -->
  <div id="forgotView" class="hidden">
    <div class="text-center mb-6">
      <h2 class="text-2xl font-bold text-gray-800">重設密碼</h2>
      <p class="text-gray-500 text-sm">我們將發送重設連結到你的電郵</p>
    </div>
    <div class="space-y-4">
      <div><label class="text-sm font-medium text-gray-700">電郵地址</label><input id="forgotEmail" type="email" placeholder="your@email.com"></div>
      <button class="btn-primary w-full" onclick="doForgot()"><i class="fas fa-paper-plane mr-2"></i>發送重設連結</button>
      <p class="text-center text-sm text-gray-500"><a href="#" onclick="showAuth('login')" class="text-indigo-600 font-medium hover:underline">返回登入</a></p>
    </div>
    <div id="forgotMsg" class="mt-3 text-sm text-center hidden"></div>
  </div>
</div>
</div>

<!-- MAIN APP -->
<div id="appSection" class="hidden">
<!-- Sidebar -->
<aside id="sidebar" class="sidebar fixed left-0 top-0 bottom-0 w-64 bg-sidebar text-white flex flex-col z-50">
  <div class="p-5 border-b border-white/10">
    <div class="flex items-center space-x-3">
      <div class="w-10 h-10 bg-indigo-500 rounded-lg flex items-center justify-center"><i class="fas fa-chart-line"></i></div>
      <div><div class="font-bold text-lg">FIT Dashboard</div><div class="text-xs text-indigo-300" id="userEmailDisplay"></div></div>
    </div>
  </div>
  <nav class="flex-1 p-4 space-y-1 overflow-y-auto" id="navMenu">
    <div class="nav-item p-3 flex items-center space-x-3 cursor-pointer active" data-page="dashboard"><i class="fas fa-chart-pie w-5"></i><span>儀表板</span></div>
    <div class="nav-item p-3 flex items-center space-x-3 cursor-pointer" data-page="customers"><i class="fas fa-users w-5"></i><span>客戶管理</span></div>
    <div class="nav-item p-3 flex items-center space-x-3 cursor-pointer" data-page="exercise"><i class="fas fa-dumbbell w-5"></i><span>運動課堂</span></div>
    <div class="nav-item p-3 flex items-center space-x-3 cursor-pointer" data-page="products"><i class="fas fa-shopping-cart w-5"></i><span>產品零售</span></div>
    <div class="nav-item p-3 flex items-center space-x-3 cursor-pointer" data-page="finance"><i class="fas fa-wallet w-5"></i><span>收支管理</span></div>
    <div class="nav-item p-3 flex items-center space-x-3 cursor-pointer" data-page="inventory"><i class="fas fa-boxes-stacked w-5"></i><span>庫存管理</span></div>
    <div class="nav-item p-3 flex items-center space-x-3 cursor-pointer" data-page="reports"><i class="fas fa-file-chart-line w-5"></i><span>報表分析</span></div>
    <div class="nav-item p-3 flex items-center space-x-3 cursor-pointer" data-page="settings"><i class="fas fa-cog w-5"></i><span>個人設定</span></div>
  </nav>
  <div class="p-4 border-t border-white/10">
    <div class="nav-item p-3 flex items-center space-x-3 cursor-pointer" onclick="doLogout()"><i class="fas fa-sign-out-alt w-5"></i><span>登出</span></div>
  </div>
</aside>

<!-- Main Content -->
<div class="main-content ml-64 min-h-screen transition-all" id="mainContent">
  <!-- Top Bar -->
  <header class="bg-white shadow-sm sticky top-0 z-40 px-6 py-4 flex items-center justify-between">
    <div class="flex items-center space-x-4">
      <button class="md:hidden text-gray-600 text-xl" onclick="toggleSidebar()"><i class="fas fa-bars"></i></button>
      <h2 class="text-xl font-bold text-gray-800" id="pageTitle">儀表板</h2>
    </div>
    <div class="flex items-center space-x-3">
      <div id="expiryAlert" class="hidden relative">
        <button class="relative p-2 text-gray-500 hover:text-indigo-600" onclick="showExpiryModal()">
          <i class="fas fa-bell text-lg"></i>
          <span class="absolute -top-1 -right-1 w-5 h-5 bg-red-500 text-white text-xs rounded-full flex items-center justify-center" id="expiryCount">0</span>
        </button>
      </div>
      <div class="w-8 h-8 bg-indigo-100 rounded-full flex items-center justify-center cursor-pointer" onclick="navigate('settings')">
        <i class="fas fa-user text-indigo-600 text-sm"></i>
      </div>
    </div>
  </header>

  <!-- Pages -->
  <div class="p-6" id="pageContainer">

    <!-- DASHBOARD PAGE -->
    <div id="page-dashboard" class="page">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6" id="statCards"></div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
        <div class="card p-5"><h3 class="font-bold text-gray-700 mb-3">收入趨勢</h3><canvas id="revenueChart"></canvas></div>
        <div class="card p-5"><h3 class="font-bold text-gray-700 mb-3">支出分類</h3><canvas id="expenseChart"></canvas></div>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
        <div class="card p-5"><h3 class="font-bold text-gray-700 mb-3">客戶來源分佈</h3><canvas id="sourceChart"></canvas></div>
        <div class="card p-5"><h3 class="font-bold text-gray-700 mb-3">分店會員分佈</h3><canvas id="branchChart"></canvas></div>
      </div>
      <div class="card p-5"><h3 class="font-bold text-gray-700 mb-4">即將到期套票</h3><div id="expiryList" class="space-y-2"></div></div>
    </div>

    <!-- CUSTOMERS PAGE -->
    <div id="page-customers" class="page hidden">
      <div class="flex flex-wrap gap-3 mb-4 items-center">
        <input id="custSearch" class="flex-1 min-w-[200px]" placeholder="🔍 搜索客戶名稱/電話..." oninput="renderCustomers()">
        <select id="custFilterBranch" class="w-auto" onchange="renderCustomers()"><option value="">全部分店</option><option>觀塘</option><option>中環</option><option>佐敦</option></select>
        <select id="custFilterSource" class="w-auto" onchange="renderCustomers()"><option value="">全部來源</option><option>廣告</option><option>轉介紹</option></select>
        <button class="btn-primary" onclick="showCustModal()"><i class="fas fa-plus mr-1"></i>新增客戶</button>
      </div>
      <div class="card overflow-x-auto"><table class="w-full text-sm" id="custTable"><thead class="bg-gray-50"><tr>
        <th class="p-3 text-left">名稱</th><th class="p-3 text-left">電話</th><th class="p-3 text-left">分店</th><th class="p-3 text-left">來源</th><th class="p-3 text-left">馬拉松</th><th class="p-3 text-left">代數</th><th class="p-3 text-center">操作</th>
      </tr></thead><tbody id="custBody"></tbody></table></div>
    </div>

    <!-- EXERCISE PAGE -->
    <div id="page-exercise" class="page hidden">
      <div class="flex flex-wrap gap-3 mb-4 items-center">
        <button class="btn-primary" onclick="showExerciseModal()"><i class="fas fa-plus mr-1"></i>新增運動收入</button>
        <select id="exFilterType" class="w-auto" onchange="renderExercise()"><option value="">全部類型</option><option value="trial">試堂</option><option value="10pt">10點套票</option><option value="35pt">35點套票</option></select>
        <input type="date" id="exFilterFrom" class="w-auto" onchange="renderExercise()">
        <span>至</span>
        <input type="date" id="exFilterTo" class="w-auto" onchange="renderExercise()">
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-4" id="exStatCards"></div>
      <div class="card overflow-x-auto"><table class="w-full text-sm"><thead class="bg-gray-50"><tr>
        <th class="p-3 text-left">日期</th><th class="p-3 text-left">客戶</th><th class="p-3 text-left">類型</th><th class="p-3 text-left">分店</th><th class="p-3 text-right">營業額</th><th class="p-3 text-right">利潤</th><th class="p-3 text-left">到期日</th><th class="p-3 text-left">負責人</th><th class="p-3 text-center">操作</th>
      </tr></thead><tbody id="exBody"></tbody></table></div>
    </div>

    <!-- PRODUCTS PAGE -->
    <div id="page-products" class="page hidden">
      <div class="flex flex-wrap gap-3 mb-4 items-center">
        <button class="btn-primary" onclick="showProductSaleModal()"><i class="fas fa-plus mr-1"></i>新增零售</button>
        <input type="date" id="psFilterFrom" class="w-auto" onchange="renderProductSales()">
        <span>至</span>
        <input type="date" id="psFilterTo" class="w-auto" onchange="renderProductSales()">
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-4" id="psStatCards"></div>
      <div class="card overflow-x-auto"><table class="w-full text-sm"><thead class="bg-gray-50"><tr>
        <th class="p-3 text-left">日期</th><th class="p-3 text-left">客戶</th><th class="p-3 text-left">分店</th><th class="p-3 text-left">產品</th><th class="p-3 text-right">金額</th><th class="p-3 text-right">利潤</th><th class="p-3 text-left">負責人</th><th class="p-3 text-center">操作</th>
      </tr></thead><tbody id="psBody"></tbody></table></div>
    </div>

    <!-- FINANCE PAGE -->
    <div id="page-finance" class="page hidden">
      <div class="flex flex-wrap gap-3 mb-4">
        <button class="tab-btn active" data-ftab="income" onclick="switchFTab(this)">收入</button>
        <button class="tab-btn" data-ftab="expense" onclick="switchFTab(this)">支出</button>
        <button class="tab-btn" data-ftab="summary" onclick="switchFTab(this)">月度總結</button>
      </div>
      <!-- Income Tab -->
      <div id="ftab-income">
        <div class="flex flex-wrap gap-3 mb-4">
          <button class="btn-primary" onclick="showIncomeModal()"><i class="fas fa-plus mr-1"></i>新增收入</button>
          <input type="month" id="incMonth" class="w-auto" onchange="renderIncome()">
        </div>
        <div class="card overflow-x-auto"><table class="w-full text-sm"><thead class="bg-gray-50"><tr>
          <th class="p-3 text-left">日期</th><th class="p-3 text-left">類別</th><th class="p-3 text-left">說明</th><th class="p-3 text-right">金額</th><th class="p-3 text-left">負責人</th><th class="p-3 text-center">操作</th>
        </tr></thead><tbody id="incBody"></tbody></table></div>
      </div>
      <!-- Expense Tab -->
      <div id="ftab-expense" class="hidden">
        <div class="flex flex-wrap gap-3 mb-4">
          <button class="btn-primary" onclick="showExpenseModal()"><i class="fas fa-plus mr-1"></i>新增支出</button>
          <input type="month" id="expMonth" class="w-auto" onchange="renderExpenses()">
        </div>
        <div class="card overflow-x-auto"><table class="w-full text-sm"><thead class="bg-gray-50"><tr>
          <th class="p-3 text-left">日期</th><th class="p-3 text-left">類別</th><th class="p-3 text-left">說明</th><th class="p-3 text-right">金額</th><th class="p-3 text-left">負責人</th><th class="p-3 text-center">操作</th>
        </tr></thead><tbody id="expBody"></tbody></table></div>
      </div>
      <!-- Summary Tab -->
      <div id="ftab-summary" class="hidden">
        <div class="flex flex-wrap gap-3 mb-4"><input type="month" id="sumMonth" class="w-auto" onchange="renderSummary()"></div>
        <div id="summaryContent"></div>
      </div>
    </div>

    <!-- INVENTORY PAGE -->
    <div id="page-inventory" class="page hidden">
      <div class="flex flex-wrap gap-3 mb-4 items-center">
        <select id="invBranch" class="w-auto" onchange="renderInventory()"><option>觀塘</option><option>中環</option></select>
        <input id="invSearch" class="flex-1 min-w-[200px]" placeholder="🔍 搜索產品名稱/編號(中英文)..." oninput="renderInventory()">
        <button class="btn-primary" onclick="showStockInModal()"><i class="fas fa-plus mr-1"></i>入貨</button>
      </div>
      <div class="card overflow-x-auto"><table class="w-full text-sm"><thead class="bg-gray-50"><tr>
        <th class="p-3 text-left">編號</th><th class="p-3 text-left">產品名稱</th><th class="p-3 text-left">英文名</th><th class="p-3 text-right">庫存</th><th class="p-3 text-right">成本</th><th class="p-3 text-center">操作</th>
      </tr></thead><tbody id="invBody"></tbody></table></div>
    </div>

    <!-- REPORTS PAGE -->
    <div id="page-reports" class="page hidden">
      <div class="flex flex-wrap gap-3 mb-4 items-center">
        <button class="tab-btn active" data-rperiod="day" onclick="switchRPeriod(this)">日</button>
        <button class="tab-btn" data-rperiod="week" onclick="switchRPeriod(this)">週</button>
        <button class="tab-btn" data-rperiod="month" onclick="switchRPeriod(this)">月</button>
        <button class="tab-btn" data-rperiod="year" onclick="switchRPeriod(this)">年</button>
        <button class="tab-btn" data-rperiod="custom" onclick="switchRPeriod(this)">自選</button>
        <input type="date" id="rptFrom" class="w-auto" onchange="renderReports()">
        <span>至</span>
        <input type="date" id="rptTo" class="w-auto" onchange="renderReports()">
        <select id="rptPerson" class="w-auto" onchange="renderReports()"><option value="">全部</option><option>Kwan</option><option>Cat</option></select>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-4 gap-4 mb-6" id="rptStatCards"></div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
        <div class="card p-5"><h3 class="font-bold text-gray-700 mb-3">收入 vs 支出</h3><canvas id="rptChart1"></canvas></div>
        <div class="card p-5"><h3 class="font-bold text-gray-700 mb-3">利潤趨勢</h3><canvas id="rptChart2"></canvas></div>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="card p-5"><h3 class="font-bold text-gray-700 mb-3">廣告 vs 轉介紹客戶</h3><canvas id="rptChart3"></canvas></div>
        <div class="card p-5"><h3 class="font-bold text-gray-700 mb-3">收入明細</h3><div id="rptDetail"></div></div>
      </div>
    </div>

    <!-- SETTINGS PAGE -->
    <div id="page-settings" class="page hidden">
      <div class="max-w-lg space-y-6">
        <div class="card p-6">
          <h3 class="font-bold text-gray-700 mb-4"><i class="fas fa-user mr-2"></i>個人資料</h3>
          <div class="space-y-3">
            <div><label class="text-sm font-medium text-gray-600">電郵</label><input id="setEmail" disabled class="bg-gray-50"></div>
            <div><label class="text-sm font-medium text-gray-600">顯示名稱</label><input id="setName"></div>
            <button class="btn-primary" onclick="updateProfile()">儲存</button>
          </div>
        </div>
        <div class="card p-6">
          <h3 class="font-bold text-gray-700 mb-4"><i class="fas fa-lock mr-2"></i>修改密碼</h3>
          <div class="space-y-3">
            <div><label class="text-sm font-medium text-gray-600">目前密碼</label><input id="setCurPass" type="password"></div>
            <div><label class="text-sm font-medium text-gray-600">新密碼</label><input id="setNewPass" type="password"></div>
            <div><label class="text-sm font-medium text-gray-600">確認新密碼</label><input id="setNewPass2" type="password"></div>
            <button class="btn-primary" onclick="changePassword()">更新密碼</button>
          </div>
        </div>
