    <div class="card p-5 stat-card border-l-4 border-purple-500"><div class="flex items-center justify-between"><div><div class="text-sm text-gray-500">本月利潤</div><div class="text-3xl font-bold ${getMonthProfit()>=0?'text-green-600':'text-red-600'}">$${getMonthProfit().toLocaleString()}</div></div><div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center"><i class="fas fa-dollar-sign text-purple-600"></i></div></div></div>
  `;

