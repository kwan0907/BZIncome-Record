function showAuth(view) {
  document.getElementById('loginView').classList.toggle('hidden', view !== 'login');
  document.getElementById('registerView').classList.toggle('hidden', view !== 'register');
  document.getElementById('forgotView').classList.toggle('hidden', view !== 'forgot');
}

async function doLogin() {
  const email = document.getElementById('loginEmail').value;
  const pass = document.getElementById('loginPass').value;
  const remember = document.getElementById('rememberMe').checked;
  if (!email || !pass) return showError('loginError', '請填寫所有欄位');
  try {
    await auth.setPersistence(remember ? firebase.auth.Auth.Persistence.LOCAL : firebase.auth.Auth.Persistence.SESSION);
    await auth.signInWithEmailAndPassword(email, pass);
  } catch(e) { showError('loginError', getAuthError(e.code)); }
}

async function doRegister() {
  const name = document.getElementById('regName').value;
  const email = document.getElementById('regEmail').value;
  const pass = document.getElementById('regPass').value;
  const pass2 = document.getElementById('regPass2').value;
  if (!name || !email || !pass) return showError('regError', '請填寫所有欄位');
  if (pass !== pass2) return showError('regError', '密碼不一致');
  if (pass.length < 6) return showError('regError', '密碼至少6位');
  try {
    const cred = await auth.createUserWithEmailAndPassword(email, pass);
    await cred.user.updateProfile({ displayName: name });
    await db.collection('users').doc(cred.user.uid).set({ name, email, createdAt: new Date().toISOString() });
  } catch(e) { showError('regError', getAuthError(e.code)); }
}

async function doForgot() {
  const email = document.getElementById('forgotEmail').value;
  if (!email) return showError('forgotMsg', '請輸入電郵');
  try {
    await auth.sendPasswordResetEmail(email, {
      url: window.location.href,
      handleCodeInApp: false
    });
    const el = document.getElementById('forgotMsg');
    el.textContent = '重設連結已發送到你的電郵！點擊連結後將自動登入。';
    el.className = 'mt-3 text-green-600 text-sm text-center';
    el.classList.remove('hidden');
  } catch(e) { showError('forgotMsg', getAuthError(e.code)); }
}

async function doLogout() {
  if (!confirm('確定要登出嗎？')) return;
  await auth.signOut();
}

function showError(id, msg) {
  const el = document.getElementById(id);
  el.textContent = msg;
  el.className = 'mt-3 text-red-500 text-sm text-center';
  el.classList.remove('hidden');
}

function getAuthError(code) {
  const map = {
