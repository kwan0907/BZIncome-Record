function switchRPeriod(btn) {
  document.querySelectorAll('[data-rperiod]').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  const period = btn.dataset.rperiod;
  const now = new Date();
  let from, to;
  if (period === 'day') { from = to = today(); }
  else if (period === 'week') { const d = new Date(); d.setDate(d.getDate() - d.getDay()); from = formatDate(d); to = today(); }
  else if (period === 'month') { from = today().substring(0, 7) + '-01'; to = today(); }
  else if (period === 'year') { from = today().substring(0, 4) + '-01-01'; to = today(); }
  else { from = ''; to = ''; }
  document.getElementById('rptFrom').value = from;
  document.getElementById('rptTo').value = to;
  renderReports();
}

function renderReports() {
  const from = document.getElementById('rptFrom')?.value || '';
  const to = document.getElementById('rptTo')?.value || '';
  const person = document.getElementById('rptPerson')?.value || '';

  let incomes = STATE.incomes;
  let expenses = STATE.expenses;
  let exSales = STATE.exerciseSales;
  let pSales = STATE.productSales;

  if (from) { incomes=incomes.filter(i=>(i.date||'')>=from); expenses=expenses.filter(i=>(i.date||'')>=from); exSales=exSales.filter(i=>(i.date||'')>=from); pSales=pSales.filter(i=>(i.date||'')>=from); }
  if (to) { incomes=incomes.filter(i=>(i.date||'')<=to); expenses=expenses.filter(i=>(i.date||'')<=to); exSales=exSales.filter(i=>(i.date||'')<=to); pSales=pSales.filter(i=>(i.date||'')<=to); }
  if (person) { incomes=incomes.filter(i=>i.person===person); expenses=expenses.filter(i=>i.person===person); exSales=exSales.filter(i=>i.person===person); pSales=pSales.filter(i=>i.person===person); }

  const totalInc = incomes.reduce((s,i) => s+(i.amount||0), 0);
  const totalExp = expenses.reduce((s,i) => s+(i.amount||0), 0);
  const exProfit = exSales.reduce((s,i) => s+(i.profit||0), 0);
  const psProfit = pSales.reduce((s,i) => s+(i.profit||0), 0);

  document.getElementById('rptStatCards').innerHTML = `
    <div class="card p-4 stat-card border-l-4 border-green-500"><div class="text-sm text-gray-500">總收入</div><div class="text-xl font-bold text-green-600">$${totalInc.toLocaleString()}</div></div>
    <div class="card p-4 stat-card border-l-4 border-red-500"><div class="text-sm text-gray-500">總支出</div><div class="text-xl font-bold text-red-600">$${totalExp.toLocaleString()}</div></div>
    <div class="card p-4 stat-card border-l-4 border-indigo-500"><div class="text-sm text-gray-500">運動利潤</div><div class="text-xl font-bold text-indigo-600">$${exProfit.toLocaleString()}</div></div>
    <div class="card p-4 stat-card border-l-4 border-purple-500"><div class="text-sm text-gray-500">零售利潤</div><div class="text-xl font-bold text-purple-600">$${psProfit.toLocaleString()}</div></div>
  `;

  // Charts
  if (charts.rpt1) charts.rpt1.destroy();
  charts.rpt1 = new Chart(document.getElementById('rptChart1'), {
    type: 'bar', data: {
      labels: ['收入', '支出'], datasets: [{ data: [totalInc, totalExp], backgroundColor: ['#10b981', '#ef4444'] }]
    }, options: { responsive: true, plugins: { legend: { display: false } } }
  });

  if (charts.rpt2) charts.rpt2.destroy();
  charts.rpt2 = new Chart(document.getElementById('rptChart2'), {
    type: 'bar', data: {
      labels: ['運動課堂', '產品零售', '淨利潤'], datasets: [{ data: [exProfit, psProfit, totalInc - totalExp], backgroundColor: ['#6366f1', '#8b5cf6', totalInc-totalExp>=0?'#10b981':'#ef4444'] }]
    }, options: { responsive: true, plugins: { legend: { display: false } } }
  });

  // Ad vs referral
  const adCusts = STATE.customers.filter(c => c.source === '廣告');
  const refCusts = STATE.customers.filter(c => c.source === '轉介紹');
  const adRevenue = exSales.filter(s => adCusts.find(c => c.id === s.customerId)).reduce((sum, s) => sum + (s.profit||0), 0)
    + pSales.filter(s => adCusts.find(c => c.id === s.customerId)).reduce((sum, s) => sum + (s.profit||0), 0);
  const refRevenue = exSales.filter(s => refCusts.find(c => c.id === s.customerId)).reduce((sum, s) => sum + (s.profit||0), 0)
    + pSales.filter(s => refCusts.find(c => c.id === s.customerId)).reduce((sum, s) => sum + (s.profit||0), 0);

  if (charts.rpt3) charts.rpt3.destroy();
  charts.rpt3 = new Chart(document.getElementById('rptChart3'), {
    type: 'bar', data: {
      labels: ['廣告客戶', '轉介紹客戶'],
      datasets: [
        { label: '人數', data: [adCusts.length, refCusts.length], backgroundColor: '#6366f1' },
        { label: '利潤', data: [adRevenue, refRevenue], backgroundColor: '#f59e0b' }
      ]
    }, options: { responsive: true }
  });

  // Ad cost analysis
  const adExpenses = expenses.filter(e => e.category?.includes('廣告')).reduce((s,i) => s+(i.amount||0), 0);
  document.getElementById('rptDetail').innerHTML = `
    <div class="space-y-2 text-sm">
      <div class="flex justify-between"><span>廣告總支出</span><span class="text-red-500 font-medium">$${adExpenses.toLocaleString()}</span></div>
      <div class="flex justify-between"><span>廣告客戶利潤</span><span class="text-green-600 font-medium">$${adRevenue.toLocaleString()}</span></div>
      <div class="flex justify-between"><span>廣告ROI</span><span class="font-bold ${adRevenue-adExpenses>=0?'text-green-600':'text-red-500'}">$${(adRevenue - adExpenses).toLocaleString()}</span></div>
      <hr>
      <div class="flex justify-between"><span>轉介紹客戶利潤</span><span class="text-green-600 font-medium">$${refRevenue.toLocaleString()}</span></div>
      <div class="flex justify-between"><span>運動課堂總筆數</span><span>${exSales.length}</span></div>
      <div class="flex justify-between"><span>產品零售總筆數</span><span>${pSales.length}</span></div>
    </div>
  `;
}

