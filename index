  const pid = document.getElementById('si_prod').value;
  const qty = parseInt(document.getElementById('si_qty').value) || 0;
  if (qty <= 0) return toast('請輸入有效數量', 'red');
  await adjustStock(branch, pid, qty);
  closeModal();
  toast(`已入貨 ${qty} 件`);
}

