function getGeneration(customer) {
  let gen = 1;
  let current = customer;
  let visited = new Set([current.id]);
  while (current.referralById) {
    const parent = STATE.customers.find(c => c.id === current.referralById);
    if (!parent || visited.has(parent.id)) break;
    visited.add(parent.id);
    if (parent.source === '轉介紹') { gen++; current = parent; }
    else break;
  }
  return gen;
}

