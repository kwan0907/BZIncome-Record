function userDoc() { return db.collection('users').doc(currentUser.uid); }

async function loadAllData() {
  const uid = currentUser.uid;
  const collections = ['customers','exerciseSales','productSales','incomes','expenses'];
  for (const col of collections) {
    const snap = await userDoc().collection(col).get();
    STATE[col] = snap.docs.map(d => ({ id: d.id, ...d.data() }));
  }
  // Load inventory
  const invSnap = await userDoc().collection('inventory').get();
  STATE.inventory = {};
  invSnap.forEach(d => { STATE.inventory[d.id] = d.data(); });

  // Load custom categories
  const userSnap = await userDoc().get();
  if (userSnap.exists) {
    const data = userSnap.data();
    if (data.expenseCategories) STATE.expenseCategories = data.expenseCategories;
    if (data.incomeCategories) STATE.incomeCategories = data.incomeCategories;
  }

  checkExpiry();
}

async function saveDoc(collection, data, id = null) {
  if (id) {
    await userDoc().collection(collection).doc(id).set(data, { merge: true });
    const idx = STATE[collection].findIndex(i => i.id === id);
    if (idx >= 0) STATE[collection][idx] = { id, ...data };
    else STATE[collection].push({ id, ...data });
  } else {
    const ref = await userDoc().collection(collection).add(data);
    STATE[collection].push({ id: ref.id, ...data });
    return ref.id;
  }
}

async function deleteDoc(collection, id) {
  await userDoc().collection(collection).doc(id).delete();
  STATE[collection] = STATE[collection].filter(i => i.id !== id);
}

