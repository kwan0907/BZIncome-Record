function filterProducts() {
  const q = (document.getElementById('mp_search')?.value || '').toLowerCase();
  const activeProducts = PRODUCTS.filter(p => !p.n.includes('已暫停'));
  const filtered = activeProducts.filter(p => !q || p.n.toLowerCase().includes(q) || p.en.toLowerCase().includes(q) || p.id.toLowerCase().includes(q));
  const tier = getSelectedTier();

  document.getElementById('mp_products').innerHTML = filtered.slice(0, 30).map(p => {
    const price = p.p[tier];
    return `<div class="flex items-center justify-between p-2 hover:bg-gray-50 border-b text-sm cursor-pointer" onclick="addToCart('${p.id}')">
      <div><span class="font-medium">${esc(p.n)}</span><span class="text-xs text-gray-400 ml-2">${esc(p.en)}</span></div>
      <div class="text-right"><span class="font-medium text-green-600">$${price}</span><button class="ml-2 text-indigo-500"><i class="fas fa-plus-circle"></i></button></div>
    </div>`;
  }).join('');
}

function getSelectedTier() {
  const sel = document.getElementById('mp_cust');
  if (!sel || !sel.value) return 0;
  return parseInt(sel.selectedOptions[0]?.dataset.tier || 0);
}

function addToCart(pid) {
  const existing = cart.find(c => c.pid === pid);
  if (existing) { existing.qty++; }
  else { cart.push({ pid, qty: 1 }); }
  renderCart();
}

function removeFromCart(pid) {
  cart = cart.filter(c => c.pid !== pid);
  renderCart();
}

function updateCartQty(pid, qty) {
  const item = cart.find(c => c.pid === pid);
  if (item) item.qty = Math.max(1, parseInt(qty) || 1);
  renderCart();
}

function updateCartPrices() { renderCart(); filterProducts(); }

function renderCart() {
  const tier = getSelectedTier();
  let total = 0, totalCost = 0;
  document.getElementById('mp_cart').innerHTML = cart.map(c => {
    const p = PRODUCTS.find(x => x.id === c.pid);
    if (!p) return '';
    const price = p.p[tier];
    const subtotal = price * c.qty;
    const costSubtotal = p.cost * c.qty;
    total += subtotal;
    totalCost += costSubtotal;
    return `<div class="flex items-center gap-2 bg-gray-50 p-2 rounded text-sm">
      <div class="flex-1">${esc(p.n)}<br><span class="text-xs text-gray-400">$${price}/件</span></div>
      <input type="number" value="${c.qty}" min="1" class="w-16 text-center" onchange="updateCartQty('${c.pid}',this.value)">
      <span class="font-medium w-20 text-right">$${subtotal}</span>
      <button onclick="removeFromCart('${c.pid}')" class="text-red-400"><i class="fas fa-times"></i></button>
    </div>`;
  }).join('') || '<div class="text-gray-400 text-sm">尚未加入產品</div>';

  const profit = total - totalCost;
  document.getElementById('mp_total').innerHTML = `
    <div class="flex justify-between"><span>零售總額:</span><strong class="text-green-600">$${total.toLocaleString()}</strong></div>
    <div class="flex justify-between"><span>產品成本 (50%):</span><span class="text-red-500">-$${totalCost.toLocaleString()}</span></div>
    <hr class="my-1"><div class="flex justify-between text-base"><span>利潤:</span><strong class="text-indigo-600">$${profit.toLocaleString()}</strong></div>
  `;
}

async function saveProductSale() {
  const custId = document.getElementById('mp_cust').value;
  if (!custId || cart.length === 0) return toast('請選擇客戶並加入產品', 'red');
  const cust = STATE.customers.find(c => c.id === custId);
  const tier = getSelectedTier();
  const branch = document.getElementById('mp_branch').value;
  let totalAmount = 0, totalCost = 0;
  const items = cart.map(c => {
    const p = PRODUCTS.find(x => x.id === c.pid);
    const price = p.p[tier];
    const sub = price * c.qty;
    const costSub = p.cost * c.qty;
    totalAmount += sub;
    totalCost += costSub;
    return { pid: c.pid, name: p.n, qty: c.qty, price, subtotal: sub, cost: costSub };
  });

  const data = {
    customerId: custId, customerName: cust.name, items, totalAmount, totalCost,
    profit: totalAmount - totalCost, date: document.getElementById('mp_date').value,
    branch, person: document.getElementById('mp_person').value, createdAt: new Date().toISOString()
  };

  await saveDoc('productSales', data);
  // Auto record income
  await saveDoc('incomes', { category: '產品零售', description: `${cust.name} - ${items.length}件產品`, amount: totalAmount, date: data.date, person: data.person, createdAt: new Date().toISOString() });
  // Update inventory
  for (const item of items) {
    const key = `${branch}_${item.pid}`;
    const current = STATE.inventory[key]?.qty || 0;
    await userDoc().collection('inventory').doc(key).set({ productId: item.pid, branch, qty: current - item.qty }, { merge: true });
    STATE.inventory[key] = { productId: item.pid, branch, qty: current - item.qty };
  }
  closeModal();
  renderProductSales();
  toast('零售記錄已儲存');
}

async function deletePSale(id) {
  if (!confirm('確定刪除？')) return;
  await deleteDoc('productSales', id);
  renderProductSales();
  toast('已刪除');
}

