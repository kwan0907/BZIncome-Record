// Biometric (WebAuthn)
async function setupBiometric() {
  if (!window.PublicKeyCredential) return toast('此裝置不支援生物認證', 'red');
  try {
    const challenge = new Uint8Array(32); crypto.getRandomValues(challenge);
    const credential = await navigator.credentials.create({
      publicKey: {
        challenge,
        rp: { name: 'FIT Dashboard' },
        user: { id: new Uint8Array(16), name: currentUser.email, displayName: currentUser.displayName || currentUser.email },
        pubKeyCredParams: [{ alg: -7, type: 'public-key' }],
        authenticatorSelection: { authenticatorAttachment: 'platform', userVerification: 'required' },
        timeout: 60000
      }
    });
    const credId = btoa(String.fromCharCode(...new Uint8Array(credential.rawId)));
    await db.collection('users').doc(currentUser.uid).update({ biometricCredId: credId, biometricEmail: currentUser.email });
    toast('生物認證設置成功！', 'green');
  } catch(e) { toast('設置失敗: ' + e.message, 'red'); }
}

async function biometricLogin() {
  toast('生物認證登入需要先在設定中設置', 'orange');
}

// Check biometric availability
async function checkBiometric() {
  if (window.PublicKeyCredential) {
    try {
      const available = await PublicKeyCredential.isUserVerifyingPlatformAuthenticatorAvailable();
      if (available) document.getElementById('biometricBtn').classList.remove('hidden');
    } catch(e) {}
  }
}

