function getMonthProfit() {
  const m = today().substring(0, 7);
  const inc = STATE.incomes.filter(i => (i.date||'').startsWith(m)).reduce((s, i) => s + (i.amount||0), 0);
  const exp = STATE.expenses.filter(i => (i.date||'').startsWith(m)).reduce((s, i) => s + (i.amount||0), 0);
  return inc - exp;
}

function renderDashboardCharts() {
  // Revenue by month (last 6 months)
  const months = [];
  for (let i = 5; i >= 0; i--) {
    const d = new Date();
    d.setMonth(d.getMonth() - i);
    months.push(d.toISOString().substring(0, 7));
  }

  const revData = months.map(m => STATE.incomes.filter(i => (i.date||'').startsWith(m)).reduce((s, i) => s + (i.amount||0), 0));
  const expData = months.map(m => STATE.expenses.filter(i => (i.date||'').startsWith(m)).reduce((s, i) => s + (i.amount||0), 0));

  if (charts.revenue) charts.revenue.destroy();
  charts.revenue = new Chart(document.getElementById('revenueChart'), {
    type: 'bar', data: {
      labels: months.map(m => m.substring(5) + '月'),
      datasets: [
        { label: '收入', data: revData, backgroundColor: '#6366f1' },
        { label: '支出', data: expData, backgroundColor: '#ef4444' }
      ]
    }, options: { responsive: true, plugins: { legend: { position: 'top' } } }
  });

  // Expense by category
  const expByCat = {};
  STATE.expenses.forEach(e => { expByCat[e.category] = (expByCat[e.category]||0) + (e.amount||0); });
  if (charts.expense) charts.expense.destroy();
  const catLabels = Object.keys(expByCat);
  const catColors = ['#ef4444','#f59e0b','#10b981','#6366f1','#8b5cf6','#ec4899','#14b8a6','#f97316'];
  charts.expense = new Chart(document.getElementById('expenseChart'), {
    type: 'doughnut', data: {
      labels: catLabels, datasets: [{ data: Object.values(expByCat), backgroundColor: catColors.slice(0, catLabels.length) }]
    }, options: { responsive: true }
  });

  // Source chart
  const adCount = STATE.customers.filter(c => c.source === '廣告').length;
  const refCount = STATE.customers.filter(c => c.source === '轉介紹').length;
  if (charts.source) charts.source.destroy();
  charts.source = new Chart(document.getElementById('sourceChart'), {
    type: 'pie', data: {
      labels: ['廣告', '轉介紹'], datasets: [{ data: [adCount, refCount], backgroundColor: ['#6366f1', '#f59e0b'] }]
    }, options: { responsive: true }
  });

  // Branch chart
  if (charts.branch) charts.branch.destroy();
  charts.branch = new Chart(document.getElementById('branchChart'), {
    type: 'pie', data: {
      labels: BRANCHES, datasets: [{ data: BRANCHES.map(b => STATE.customers.filter(c => c.branch === b).length), backgroundColor: ['#3b82f6', '#10b981', '#8b5cf6'] }]
    }, options: { responsive: true }
  });
}

function renderExpiryPreview() {
  const upcoming = STATE.exerciseSales.filter(s => s.expiryDate && s.expiryDate >= today() && s.expiryDate <= addDays(today(), 30)).sort((a, b) => a.expiryDate.localeCompare(b.expiryDate));
  document.getElementById('expiryList').innerHTML = upcoming.length ? upcoming.map(s => {
    const days = daysBetween(today(), s.expiryDate);
    return `<div class="flex items-center justify-between p-3 bg-orange-50 rounded-lg">
      <div><span class="font-medium">${esc(s.customerName)}</span><span class="text-sm text-gray-500 ml-2">${s.type==='10pt'?'10點':'35點'}套票</span></div>
      <div class="text-right"><span class="text-orange-600 font-medium">${s.expiryDate}</span><span class="text-xs text-orange-500 ml-2">(${days}天後到期)</span></div>
    </div>`;
  }).join('') : '<div class="text-center text-gray-400 py-4">暫無即將到期的套票</div>';
}

