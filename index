function renderSettings() {
  document.getElementById('setEmail').value = currentUser?.email || '';
  document.getElementById('setName').value = currentUser?.displayName || '';
  renderCategories();
}

async function updateProfile() {
  const name = document.getElementById('setName').value.trim();
  if (!name) return toast('請填寫名稱', 'red');
  await currentUser.updateProfile({ displayName: name });
  await userDoc().update({ name });
  toast('個人資料已更新');
}

async function changePassword() {
  const cur = document.getElementById('setCurPass').value;
  const newP = document.getElementById('setNewPass').value;
  const newP2 = document.getElementById('setNewPass2').value;
  if (!cur || !newP) return toast('請填寫所有欄位', 'red');
  if (newP !== newP2) return toast('新密碼不一致', 'red');
  if (newP.length < 6) return toast('密碼至少6位', 'red');
  try {
    const cred = firebase.auth.EmailAuthProvider.credential(currentUser.email, cur);
    await currentUser.reauthenticateWithCredential(cred);
    await currentUser.updatePassword(newP);
    document.getElementById('setCurPass').value = '';
    document.getElementById('setNewPass').value = '';
    document.getElementById('setNewPass2').value = '';
    toast('密碼已更新');
  } catch(e) { toast('密碼更新失敗: ' + getAuthError(e.code), 'red'); }
}

async function deleteAccount() {
  if (!confirm('確定要刪除帳號？此操作不可逆！')) return;
  if (!confirm('真的確定嗎？所有資料將永久刪除！')) return;
  try {
    const uid = currentUser.uid;
    // Delete all subcollections
    for (const col of ['customers','exerciseSales','productSales','incomes','expenses','inventory']) {
      const snap = await userDoc().collection(col).get();
      for (const doc of snap.docs) await doc.ref.delete();
    }
    await userDoc().delete();
    await currentUser.delete();
    toast('帳號已刪除');
  } catch(e) { toast('刪除失敗，請重新登入後再試', 'red'); }
}

function renderCategories() {
  document.getElementById('customCategories').innerHTML =
    STATE.expenseCategories.map(c => `<div class="flex items-center justify-between bg-red-50 p-2 rounded text-sm"><span><i class="fas fa-minus-circle text-red-400 mr-2"></i>${esc(c)}</span><button onclick="removeCategory('expense','${esc(c)}')" class="text-red-400 hover:text-red-600"><i class="fas fa-times"></i></button></div>`).join('') +
    STATE.incomeCategories.map(c => `<div class="flex items-center justify-between bg-green-50 p-2 rounded text-sm"><span><i class="fas fa-plus-circle text-green-400 mr-2"></i>${esc(c)}</span><button onclick="removeCategory('income','${esc(c)}')" class="text-green-400 hover:text-green-600"><i class="fas fa-times"></i></button></div>`).join('');
}

async function addCategory() {
  const type = document.getElementById('newCatType').value;
  const name = document.getElementById('newCatName').value.trim();
  if (!name) return;
  if (type === 'expense') STATE.expenseCategories.push(name);
  else STATE.incomeCategories.push(name);
  await userDoc().update({ expenseCategories: STATE.expenseCategories, incomeCategories: STATE.incomeCategories });
  document.getElementById('newCatName').value = '';
  renderCategories();
  toast('類別已新增');
}

async function removeCategory(type, name) {
  if (type === 'expense') STATE.expenseCategories = STATE.expenseCategories.filter(c => c !== name);
  else STATE.incomeCategories = STATE.incomeCategories.filter(c => c !== name);
  await userDoc().update({ expenseCategories: STATE.expenseCategories, incomeCategories: STATE.incomeCategories });
  renderCategories();
}

// ========================================
// EXPIRY CHECK
// ========================================
function checkExpiry() {
  const upcoming = STATE.exerciseSales.filter(s => s.expiryDate && s.expiryDate >= today() && s.expiryDate <= addDays(today(), 30));
  const expired = STATE.exerciseSales.filter(s => s.expiryDate && s.expiryDate < today());
  const total = upcoming.length + expired.length;
  if (total > 0) {
    document.getElementById('expiryAlert').classList.remove('hidden');
    document.getElementById('expiryCount').textContent = total;
  } else {
    document.getElementById('expiryAlert').classList.add('hidden');
  }
}

function showExpiryModal() {
  const upcoming = STATE.exerciseSales.filter(s => s.expiryDate && s.expiryDate >= today() && s.expiryDate <= addDays(today(), 30));
  const expired = STATE.exerciseSales.filter(s => s.expiryDate && s.expiryDate < today());
  const html = `
    <div class="space-y-3">
      ${expired.length ? `<h4 class="font-bold text-red-600">已過期 (${expired.length})</h4>` + expired.map(s => `<div class="p-3 bg-red-50 rounded flex justify-between"><span>${esc(s.customerName)} (${s.type})</span><span class="text-red-500">${s.expiryDate}</span></div>`).join('') : ''}
      ${upcoming.length ? `<h4 class="font-bold text-orange-600">即將到期 (${upcoming.length})</h4>` + upcoming.map(s => `<div class="p-3 bg-orange-50 rounded flex justify-between"><span>${esc(s.customerName)} (${s.type})</span><span class="text-orange-500">${s.expiryDate} (${daysBetween(today(), s.expiryDate)}天)</span></div>`).join('') : ''}
      ${!expired.length && !upcoming.length ? '<div class="text-center text-gray-400 py-4">暫無提醒</div>' : ''}
    </div>`;
  showModal('套票到期提醒', html);
}

// ========================================
// UTILITY FUNCTIONS
// ========================================
function today() { return new Date().toISOString().split('T')[0]; }
function formatDate(d) { return d.toISOString().split('T')[0]; }
function addDays(dateStr, days) {
  const d = new Date(dateStr);
  d.setDate(d.getDate() + days);
  return formatDate(d);
}
function daysBetween(d1, d2) {
  return Math.ceil((new Date(d2) - new Date(d1)) / 86400000);
}
function esc(s) { if (!s) return ''; const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

